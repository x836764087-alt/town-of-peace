{
  "name": "town-of-peace",
  "version": "2.0.0",
  "description": "桃源镇 Living Town — AI-powered pixel art town simulation",
  "main": "server/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:seed": "tsx src/index.ts --seed 42 --years 10",
    "dev:new": "tsx src/index.ts --new --seed 42 --years 10",
    "server:dev": "node server/main.js",
    "server:start": "NODE_ENV=production node server/main.js",
    "migrate": "node server/persistence/migrations.js",
    "test": "vitest run",
    "lint": "eslint server/",
    "server:watch": "node --watch server/main.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "seedrandom": "^3.0.5",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/seedrandom": "^3.0.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
